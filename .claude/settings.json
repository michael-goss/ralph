{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git init:*)",
      "Bash(git clone:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git reset:*)",
      "Bash(git worktree:*)",
      "Bash(git remote:*)",
      "Bash(git rebase:*)",
      "Bash(git push:*)",
      "Bash(rm:* .git)",
      "Bash(rm:* .git/*)",
      "Edit(**/.git/**)",
      "Write(**/.git/**)"
    ],
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)"
    ]
  }
}
